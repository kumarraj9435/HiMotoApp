<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:gravity="center"
    android:padding="24dp">

    <!-- Logo / Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎤"
        android:textSize="72sp"
        android:layout_marginBottom="16dp"/>

    <!-- App Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hi Moto"
        android:textSize="36sp"
        android:textColor="#e94560"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice Assistant"
        android:textSize="16sp"
        android:textColor="#a0a0c0"
        android:layout_marginBottom="32dp"/>

    <!-- Status Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#16213e"
        android:padding="20dp"
        android:orientation="vertical"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏳ Loading..."
            android:textColor="#e0e0ff"
            android:textSize="15sp"
            android:lineSpacingExtra="6dp"/>
    </LinearLayout>

    <!-- Start Button -->
    <Button
        android:id="@+id/startBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="▶  START - Hi Moto"
        android:textSize="16sp"
        android:textColor="#ffffff"
        android:backgroundTint="#e94560"
        android:layout_marginBottom="12dp"/>

    <!-- Stop Button -->
    <Button
        android:id="@+id/stopBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="⏹  STOP Service"
        android:textSize="16sp"
        android:textColor="#ffffff"
        android:backgroundTint="#444466"
        android:enabled="false"/>

    <!-- Commands hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\nCommands:\n• Hi Moto → Activate\n• Open WhatsApp / Call Naam\n• Call band karo\n• Koi bhi sawaal"
        android:textColor="#6060a0"
        android:textSize="13sp"
        android:layout_marginTop="24dp"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
